{
    "$schema": "https://hypercube-neo.dev/schema/v4.json",
    "name": "Heat Diffusion Showcase CPU",
    "version": "1.0.0",
    "engine": {
        "name": "Heat-CPU",
        "version": "1.0.0",
        "faces": [
            { "name": "temperature", "type": "scalar", "isPingPong": true },
            { "name": "obstacles", "type": "mask", "isReadOnly": true }
        ],
        "rules": [
            {
                "type": "neo-heat",
                "source": "temperature",
                "params": {
                    "diffusion_rate": 0.2,
                    "decay_factor": 0.999
                }
            }
        ],
        "requirements": {
            "ghostCells": 1,
            "pingPong": true
        }
    },
    "config": {
        "mode": "cpu",
        "dimensions": { "nx": 512, "ny": 256, "nz": 1 },
        "chunks": { "x": 2, "y": 1 },
        "boundaries": {
            "all": { "role": "wall" }
        },
        "params": {
            "pixelScale": 2.0
        },
        "objects": [
            {
                "id": "heat_eater",
                "type": "circle",
                "position": { "x": 231, "y": 103 },
                "dimensions": { "w": 50, "h": 50 },
                "properties": {
                    "obstacles": 0.7,
                    "temperature": 0.0
                },
                "isVisible": false,
                "isBaked": false
            },
            {
                "id": "source_1",
                "type": "circle",
                "position": { "x": 384, "y": 116 },
                "dimensions": { "w": 24, "h": 24 },
                "properties": {
                    "temperature": 4.0
                }
            },
            {
                "id": "source_2",
                "type": "circle",
                "position": { "x": 148, "y": 120 },
                "dimensions": { "w": 16, "h": 16 },
                "properties": {
                    "temperature": 3.0
                }
            }
        ],
        "engine": "Heat-CPU"
    }
}
