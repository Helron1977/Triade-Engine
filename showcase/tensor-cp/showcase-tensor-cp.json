{
    "$schema": "../../manifest-schema.json",
    "name": "Tensor CP Showcase",
    "engine": {
        "type": "neo-tensor-cp-v1",
        "params": {
            "rank": 10,
            "maxIterations": 100,
            "tolerance": 1e-4,
            "regularization": 0.05
        },
        "faces": [
            { "name": "mode_a", "type": "factor", "isPingPong": false, "isSynchronized": true },
            { "name": "mode_b", "type": "factor", "isPingPong": false, "isSynchronized": true },
            { "name": "mode_c", "type": "factor", "isPingPong": false, "isSynchronized": true },
            { "name": "target", "type": "tensor", "isPingPong": false, "isSynchronized": true },
            { "name": "reconstruction", "type": "tensor", "isPingPong": false, "isSynchronized": true }
        ],
        "rules": [
            { "type": "neo-tensor-cp-v1" }
        ],
        "requirements": {
            "ghostCells": 0,
            "pingPong": false
        }
    },
    "config": {
        "mode": "cpu",
        "dimensions": { "nx": 32, "ny": 32, "nz": 8 },
        "chunks": { "x": 1, "y": 1 },
        "boundaries": {
            "all": { "role": "wall" }
        },
        "params": {
            "rank": 10,
            "maxIterations": 100,
            "regularization": 0.05
        }
    },
    "visualProfile": {
        "colormap": "viridis",
        "range": [0, 5]
