{
  "name": "hypercube-compute",
  "version": "4.0.0-alpha.2",
  "description": "A high-performance O(1) tensor-based compute engine for Web and Node.js environments.",
  "main": "dist/HypercubeNeo.js",
  "module": "dist/HypercubeNeo.mjs",
  "types": "dist/HypercubeNeo.d.ts",
  "scripts": {
    "build": "tsup HypercubeNeo.ts --format cjs,esm --dts --clean",
    "dev": "tsup HypercubeNeo.ts --format cjs,esm --dts --watch",
    "test": "vitest run tests",
    "test:watch": "vitest tests",
    "showcase": "vite",
    "neo:showcase": "vite"
  },
  "keywords": [
    "tensor",
    "compute",
    "O(1)",
    "engine",
    "physics",
    "webassembly",
    "web-workers",
    "lattice-boltzmann"
  ],
  "author": "Helron1977",
  "license": "MIT",
  "devDependencies": {
    "@webgpu/types": "^0.1.69",
    "tsup": "^8.0.2",
    "typescript": "^5.3.3",
    "vitest": "^4.0.18"
  }
}