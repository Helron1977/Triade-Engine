{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "node",
        "esModuleInterop": true,
        "strict": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "declaration": true,
        "declarationMap": true,
        "outDir": "./dist",
        "lib": [
            "ES2022",
            "DOM",
            "DOM.Iterable"
        ],
        "types": [
            "@webgpu/types"
        ]
    },
    "include": [
        "core/**/*",
        "io/**/*",
        "showcase/**/*",
        "tests/**/*",
        "helpers/**/*",
        "tools/**/*",
        "HypercubeNeo.ts",
        "env.d.ts"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ]
}